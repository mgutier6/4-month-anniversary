<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>One Month With You ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    min-height:100vh;
    background:linear-gradient(135deg,#ff9a9e,#fad0c4);
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
    color:white;
}

.container{
    max-width:800px;
    text-align:center;
    padding:40px;
    z-index:2;
}

h1{
    font-size:3rem;
    margin-bottom:10px;
}

.subtitle{
    font-size:1.2rem;
    margin-bottom:30px;
}

.card{
    background:rgba(255,255,255,0.15);
    backdrop-filter:blur(10px);
    border-radius:20px;
    padding:30px;
    box-shadow:0 8px 30px rgba(0,0,0,0.2);
}

.counter{
    font-size:2rem;
    margin:20px 0;
    font-weight:bold;
}

.message{
    line-height:1.8;
    font-size:1.1rem;
}

.highlight{
    color:#fff4b5;
    font-weight:bold;
}

.heart{
    position:absolute;
    color:white;
    font-size:20px;
    animation:float 8s linear infinite;
    opacity:0.7;
}

@keyframes float{
    from{
        transform:translateY(100vh);
        opacity:0;
    }
    10%{
        opacity:0.8;
    }
    to{
        transform:translateY(-120px);
        opacity:0;
    }
}

button{
    margin-top:25px;
    border:none;
    padding:12px 25px;
    border-radius:30px;
    cursor:pointer;
    background:white;
    color:#ff6b81;
    font-weight:bold;
    transition:0.3s;
}

button:hover{
    transform:scale(1.05);
}

#loveMessage{
    margin-top:20px;
    font-size:1.1rem;
    min-height:50px;
}
</style>
</head>
<body>

<div class="container">

    <h1>❤️ One Month With You ❤️</h1>

    <p class="subtitle">
        Distance may separate us, but my heart is always with you.
    </p>

    <div class="card">

        <h2>We've Been Together For</h2>

        <div class="counter" id="counter"></div>

        <div class="message">
            One month ago, we started something special.

            <br><br>

            Even with miles between us, you've become one of the best parts of my day.

            <br><br>

            Every message.
            Every call.
            Every laugh.

            <br><br>

            They all remind me how lucky I am to have you.

            <br><br>

            <span class="highlight">
                Thank you for making long distance feel a little less far.
            </span>
        </div>

        <button onclick="showLoveNote()">
            Click Me ❤️
        </button>

        <div id="loveMessage"></div>

    </div>

</div>

<script>

// CHANGE THIS DATE
const anniversaryStart = new Date("2025-05-30");

function updateCounter() {
    const now = new Date();

    const diff = now - anniversaryStart;

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));

    document.getElementById("counter").innerHTML =
        `${days} Days Together ✨`;
}

updateCounter();

const notes = [
    "You're my favorite notification ❤️",
    "Every mile is worth it because it's you 💕",
    "Thank you for every late-night call 🌙",
    "You're my favorite part of every day ☀️",
    "Distance is temporary, us is forever ❤️",
    "One month down, forever to go 🥰"
];

function showLoveNote(){
    const random =
        notes[Math.floor(Math.random() * notes.length)];

    document.getElementById("loveMessage").innerHTML = random;
}

// Floating hearts
function createHeart(){
    const heart = document.createElement("div");

    heart.classList.add("heart");
    heart.innerHTML = "❤️";

    heart.style.left = Math.random() * window.innerWidth + "px";
    heart.style.fontSize = (15 + Math.random()*25) + "px";
    heart.style.animationDuration = (5 + Math.random()*5) + "s";

    document.body.appendChild(heart);

    setTimeout(()=>{
        heart.remove();
    },10000);
}

setInterval(createHeart,300);

</script>

</body>
</html>
